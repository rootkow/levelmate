{
  "name": "levelmate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "npm run typecheck && npm run build:demo && npm run build:extension",
    "build:demo": "vite build --config vite.config.ts",
    "build:extension": "node scripts/build-extension.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ."
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
