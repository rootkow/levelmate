{
  "manifest_version": 3,
  "name": "LevelMate",
  "version": "0.1.0",
  "description": "Locally smooths volume changes in accessible HTML5 video.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "LevelMate",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "109.0"
    }
  }
}
